# HTTP server
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# Safety switch. When true (the default), scenarios simulate load in-process and
# send NO real traffic. Set to false ONLY to hit a target you are authorised to
# test. With no STORM_TARGET_BASE_URL set, dry-run is forced regardless.
DRY_RUN=true

# Base URL for simulated traffic. Leave empty to stay in dry-run.
# STORM_TARGET_BASE_URL=http://localhost:8081/anything

# Storm sizing
DEFAULT_STORM_SIZE=5000      # events per storm when the request omits count
MAX_STORM_SIZE=20000         # hard ceiling; larger requests are clamped
CONCURRENCY=100              # max in-flight requests
REQUEST_TIMEOUT_SECONDS=10

# Per-scenario upstreams (optional). Unset endpoints fall back to
# STORM_TARGET_BASE_URL + a conventional path.
# DNB_URL=
# VALITIVE_URL=
# CREDITSAFE_URL=
# CRM_URL=
# ALARM_GATEWAY_URL=

# Deterministic synthetic data when >= 0; -1 leaves Faker unseeded.
FAKER_SEED=-1

# Observability
METRICS_ENABLED=true
